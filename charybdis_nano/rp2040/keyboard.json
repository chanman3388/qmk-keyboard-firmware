{
    "keyboard_name": "Charybdis Nano (3x5) RP2040",
    "usb": {
        "device_version": "2.0.0"
    },
    "features": {
        "bootmagic": true,
        "mousekey": true,
        "extrakey": true,
        "rgb_matrix": true,
        "pointing_device": true
    },
    "ws2812": {
        "pin": "GP0",
        "driver": "vendor"
    },
    "rgb_matrix": {
        "driver": "ws2812"
    },
    "matrix_pins": {
        "cols": [
            "GP28",
            "GP21",
            "GP6",
            "GP7",
            "GP8"
        ],
        "rows": [
            "GP26",
            "GP5",
            "GP4",
            "GP9"
        ]
    },
    "split": {
        "enabled": true,
        "serial": {
            "driver": "vendor",
            "pin": "GP1"
        }
    },
    "diode_direction": "ROW2COL",
    "development_board": "elite_pi"
}
